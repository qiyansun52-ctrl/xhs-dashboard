# 把这个文件复制一份，改名为 .env，填入你的 Supabase 信息
# 不要把 .env 上传到 GitHub（已在 .gitignore 中排除）

VITE_SUPABASE_URL=https://你的项目ID.supabase.co
VITE_SUPABASE_ANON_KEY=你的anon_public_key

# AI 搜索中心
# 浏览器可见的内部共享 token，只用于本地/内网轻量校验；不要放 Supabase service_role 或任何模型供应商密钥。
VITE_AI_API_URL=http://127.0.0.1:8001
VITE_AI_API_KEY=team-internal-secret
